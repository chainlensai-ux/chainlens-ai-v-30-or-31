{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "functions": {
    "app/api/scan/route.ts": { "maxDuration": 60, "runtime": "nodejs20.x" },
    "app/api/scan-v2/route.ts": { "maxDuration": 60, "runtime": "nodejs20.x" },
    "app/api/scan-v2/modules/*/route.ts": { "maxDuration": 60, "runtime": "nodejs20.x" },
    "app/api/diagnostics/*/route.ts": { "runtime": "nodejs20.x" }
  }
}
