{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "functions": {
    "app/api/scan/route.ts": { "maxDuration": 60 },
    "app/api/scan-v2/route.ts": { "maxDuration": 60 },
    "app/api/scan-v2/modules/*/route.ts": { "maxDuration": 60 },
    "app/api/scan-v2/full-scan/route.ts": { "maxDuration": 300 }
  }
}
