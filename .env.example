# ChainLens AI — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is excluded by .gitignore.

# ── Vercel KV (Token Scanner response cache, lib/server/cache/tokenCache.ts) ───
# Provision a Vercel KV store and these are auto-populated by Vercel; without them,
# the token cache silently no-ops (Token Scanner still works, just uncached).
KV_REST_API_URL=<kv-rest-api-url>
KV_REST_API_TOKEN=<kv-rest-api-token>

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Optional: direct DB URL (only needed for migrations)
# SUPABASE_URL=postgresql://...

# ── Anthropic (Clark AI) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Blockchain / Data providers ───────────────────────────────────────────────
ZERION_KEY=<zerion-api-key>
GOLDRUSH_API_KEY=<goldrush-key>
# Optional — CoinGecko demo API key, used as the x-cg-demo-api-key header by the wallet scanner's
# multi-provider historical pricing fallback (src/modules/pricingAtTimeEngine/sources/
# multiProviderPriceSource.ts). Works without it too (public rate limits apply).
COINGECKO_API_KEY=<coingecko-demo-api-key>
# Alchemy RPC keys — Base is required for LP burn/lock proof; ETH/Polygon/BNB are optional.
# Set either ALCHEMY_BASE_KEY (key only) or ALCHEMY_BASE_RPC_URL (full URL).
# Without ALCHEMY_BASE_KEY or ALCHEMY_BASE_RPC_URL, Base LP V2 proof falls back to
# "unverified" and _debug.lpDiagnostics.rpcSkippedReason = "missing_base_rpc_env".
ALCHEMY_BASE_KEY=<alchemy-base-key>
ALCHEMY_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<key>
# Without ALCHEMY_ETHEREUM_KEY, ETH LP V2 proof falls back similarly
# (_debug.lpDiagnostics.rpcSkippedReason = "missing_eth_rpc_env").
ALCHEMY_ETHEREUM_KEY=<alchemy-eth-key>
ALCHEMY_POLYGON_KEY=<alchemy-polygon-key>
ALCHEMY_BNB_KEY=<alchemy-bnb-key>
# Required for the V2 wallet scanner's Arbitrum support (src/modules/providerFetchWindow,
# recoveryPolicy, holdings). Without it, Arbitrum falls back to the same "no_api_key_configured"
# provider-unavailable handling every other chain already uses.
ALCHEMY_ARBITRUM_KEY=<alchemy-arbitrum-key>
# HyperEVM (Hyperliquid's EVM, chain ID 999) is a supported chain slug in the V2 wallet scanner's
# SupportedChain union, but neither GoldRush/Covalent nor Alchemy has a codebase-verified chain
# slug for it yet — see src/modules/providerFetchWindow/types.ts and src/modules/providerFetchWindow/
# utils.ts's ALCHEMY_VERIFIED_CHAINS/GOLDRUSH_VERIFIED_CHAIN_SLUGS. These two vars are reserved,
# not yet wired to a working request path:
#   - ALCHEMY_HYPEREVM_KEY: for whenever Alchemy adds verified HyperEVM support.
#   - HYPEREVM_RPC_URL: for a future native-RPC (eth_getLogs) fetcher, which needs a verified
#     HyperEVM block-time/block-range estimate before it can safely window a 90-day fetch — not
#     built yet (see the TODO in providerFetchWindow/types.ts).
# Until either is wired up, HyperEVM scans structurally participate in every other stage (chain
# selection, timelines, FIFO, bridge detection, behaviorIntel) but fetch zero real events.
ALCHEMY_HYPEREVM_KEY=<alchemy-hyperevm-key-reserved-not-yet-wired>
HYPEREVM_RPC_URL=<hyperevm-rpc-url-reserved-not-yet-wired>
# Optional explorer keys (fallback chain data)
BASESCAN_API_KEY=<basescan-key>
ETHERSCAN_API_KEY=<etherscan-key>
# Optional: GoPLus token safety
GOPLUS_APP_KEY=<goplus-key>
GOPLUS_APP_SECRET=<goplus-secret>

# ── WalletConnect ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=<walletconnect-project-id>
# Fallback name (some integrations use WALLETCONNECT_ID)
NEXT_PUBLIC_WALLETCONNECT_ID=<walletconnect-project-id>

# ── Payments ──────────────────────────────────────────────────────────────────
# NowPayments crypto checkout
NOWPAYMENTS_API_KEY=<nowpayments-api-key>
NOWPAYMENTS_IPN_SECRET=<nowpayments-ipn-secret>
# LemonSqueezy (fiat)
LEMONSQUEEZY_WEBHOOK_SECRET=<lemonsqueezy-webhook-secret>
LEMONSQUEEZY_PRO_VARIANT_ID=<variant-id>
LEMONSQUEEZY_ELITE_VARIANT_ID=<variant-id>

# ── Email / Notifications ─────────────────────────────────────────────────────
RESEND_API_KEY=re_...
AFFILIATE_FROM_EMAIL=affiliates@chainlensai.app
AFFILIATE_NOTIFY_EMAIL=team@chainlensai.app

# ── Webhooks ──────────────────────────────────────────────────────────────────
ALCHEMY_WEBHOOK_SIGNING_KEY=<alchemy-webhook-signing-key>
# Set to "true" to enable background webhook processing
WEBHOOKS_ENABLED=true

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.chainlensai.app
# Dev/beta override — never set to "true" in production
# BETA_ALL_ELITE=false

# ── Preview deployment password gate (proxy.ts, app/preview-login) ────────────
# Only enforced when Vercel's own VERCEL_ENV === "preview" — never on production, never locally.
# Without this set, preview-login always rejects every password (fails closed, never open).
PREVIEW_PASSWORD=<preview-deployment-password>
